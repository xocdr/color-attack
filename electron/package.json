{
  "name": "ascend",
  "version": "1.0.0",
  "description": "Ascend — Electron wrapper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager .. \"Ascend\" --platform=win32 --arch=x64 --electron-version=29.4.6 --out=../dist --overwrite --ignore=electron/node_modules --ignore=dist",
    "build-mac": "electron-packager .. \"Ascend\" --platform=darwin --arch=x64 --electron-version=29.4.6 --out=../dist --overwrite --ignore=electron/node_modules --ignore=dist"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-packager": "^17.1.2"
  }
}
